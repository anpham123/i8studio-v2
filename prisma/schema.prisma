generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

model Post {
  id              String    @id @default(cuid())
  title           String
  titleJa         String    @default("")
  slug            String    @unique
  content         String    @default("")
  contentJa       String    @default("")
  excerpt         String    @default("")
  excerptJa       String    @default("")
  coverImage      String    @default("")
  category        String    @default("NEWS")
  status          String    @default("DRAFT")
  metaTitle       String    @default("")
  metaDescription String    @default("")
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Work {
  id               String   @id @default(cuid())
  title            String
  titleJa          String   @default("")
  subtitle         String   @default("")
  category         String   @default("3DCG")      // 3DCG | Animation | VR | BIM
  type             String   @default("still")     // still | animation | composite | vr360 | walkthrough | ar | digital
  buildingCategory String   @default("residential") // residential | apartment | resort | commercial | office | public | urban
  image            String   @default("")
  beforeImage      String   @default("")
  videoUrl         String   @default("")           // YouTube embed URL
  vrUrl            String   @default("")           // VR360 iframe URL (e.g. https://vr.i8studio.vn/360/...)
  order            Int      @default(0)
  featured         Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model Service {
  id            String   @id @default(cuid())
  name          String
  nameJa        String   @default("")
  slug          String   @unique
  description   String   @default("")
  descriptionJa String   @default("")
  icon          String   @default("")
  image         String   @default("")
  priceHint     String   @default("")
  priceHintJa   String   @default("")
  order         Int      @default(0)
  createdAt     DateTime @default(now())
}

model Slide {
  id         String   @id @default(cuid())
  title      String
  titleJa    String   @default("")
  subtitle   String   @default("")
  subtitleJa String   @default("")
  image      String   @default("")
  gradient   String   @default("")
  order      Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model QA {
  id         String   @id @default(cuid())
  question   String
  questionJa String   @default("")
  answer     String
  answerJa   String   @default("")
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

model Testimonial {
  id            String   @id @default(cuid())
  clientName    String
  clientTitle   String   @default("")
  clientCompany String   @default("")
  clientPhoto   String   @default("")
  quote         String
  quoteJa       String   @default("")
  rating        Int      @default(5)
  featured      Boolean  @default(false)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logo      String   @default("")
  url       String   @default("")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model CaseStudy {
  id          String   @id @default(cuid())
  title       String
  titleJa     String   @default("")
  slug        String   @unique
  client      String   @default("")
  challenge   String   @default("")
  challengeJa String   @default("")
  solution    String   @default("")
  solutionJa  String   @default("")
  result      String   @default("")
  resultJa    String   @default("")
  beforeImage String   @default("")
  afterImage  String   @default("")
  metrics     String   @default("")
  serviceType String   @default("")
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @default("")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  service   String   @default("")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String   @default("")
  source    String   @default("")
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  page      String   @default("")
  metadata  String   @default("")
  createdAt DateTime @default(now())
}

model Flipbook {
  id            String   @id @default(cuid())
  title         String
  titleJa       String   @default("")
  description   String   @default("")
  descriptionJa String   @default("")
  coverImage    String   @default("")
  pdfUrl        String
  order         Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BlogPost {
  id               String   @id @default(cuid())
  slug             String   @unique

  // Hero section
  category         String   @default("")
  eyebrow          String   @default("")
  title            String
  titleJp          String   @default("")
  subtitle         String   @default("")
  heroImage        String   @default("")

  // Intro section
  introDropcap     String   @default("")
  introPullquote   String   @default("")

  // Main content sections — stored as JSON array
  sections         String   @default("[]")

  // Comparison / Insight blocks
  comparisonBefore String   @default("")
  comparisonAfter  String   @default("")
  insightHeading   String   @default("")
  insightBody      String   @default("")

  // Metadata
  excerpt          String   @default("")
  coverImage       String   @default("")
  author           String   @default("")
  authorRole       String   @default("")
  readTime         Int      @default(5)
  publishedAt      DateTime @default(now())
  isPublished      Boolean  @default(false)
  isFeatured       Boolean  @default(false)

  // Multilingual
  locale           String   @default("ja")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CompositeExample {
  id          String   @id @default(cuid())
  title       String
  titleJp     String?
  category    String   // e.g. "Residential", "Commercial"
  location    String?
  beforeImage String   // URL to before/site photo
  afterImage  String   // URL to after/composite
  isFeatured  Boolean  @default(false) // featured = shows in the hero slider position
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


