# Copy this to .env.local and fill in the values

DATABASE_URL="file:./prisma/data/i8studio.db"

# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET="replace-with-64-char-random-string"

# Production URL
NEXTAUTH_URL="https://demo.i8studio.vn"

# Used by next-sitemap for sitemap.xml generation
NEXT_PUBLIC_SITE_URL="https://demo.i8studio.vn"
